{
  "name": "enso",
  "version": "1.0.0RC",
  "description": "A Web component framework that simplifies development by handling boilerplate code, providing an intuitive interface for component derivation, and enabling code separation.",
  "main": "./dist/enso.es.js",
  "module": "dist/enso.es.js",
  "exports": {
    ".": {
      "import": "./dist/enso.es.js",
      "require": "./dist/enso.es.js"
    },
    "./helpers": {
      "import": "./dist/helpers.es.js",
      "require": "./dist/helpers.es.js"
    }
  },
  "type": "module",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:build": "BUILD=1 vitest run",
    "coverage": "vitest run --coverage",
    "test:browser": "vitest --config=vitest.browser.config.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seanyoung247/enso.git"
  },
  "keywords": [
    "Web",
    "Component"
  ],
  "author": "Sean Young",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/seanyoung247/enso/issues"
  },
  "homepage": "https://github.com/seanyoung247/enso#readme",
  "devDependencies": {
    "@vitest/browser-webdriverio": "^4.0.14",
    "@vitest/coverage-v8": "^4.0.14",
    "esbuild": "^0.27.0",
    "eslint": "^8.44.0",
    "jsdom": "^27.0.0",
    "terser": "^5.44.1",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
